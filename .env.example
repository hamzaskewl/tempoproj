# Twitch OAuth (required for login + clip creation)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Claude API (required for moment classification)
ANTHROPIC_API_KEY=

# PostgreSQL (optional — runs in-memory without it)
DATABASE_URL=

# Admin — this Twitch username gets admin role automatically
ADMIN_TWITCH=

# LLM budget cap in USD (default $20)
LLM_BUDGET_USD=20

# Server port (default 3000)
PORT=3000

# Tempo MPP (optional — for paid API endpoints)
WALLET_ADDRESS=
TEMPO_SESSION_KEY=
TEMPO_RPC=https://rpc.tempo.xyz
