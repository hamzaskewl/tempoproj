# Twitch OAuth (required for login + clip creation)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Claude API (required for moment classification)
ANTHROPIC_API_KEY=

# PostgreSQL (optional — runs in-memory without it)
DATABASE_URL=

# Admin — this Twitch username gets admin role automatically
ADMIN_TWITCH=

# LLM budget cap in USD (default $20)
LLM_BUDGET_USD=20

# Server port (default 3000)
PORT=3000

# Spike detector v2 — EWMA + z-score + shape confirmation + peak-timed capture.
# Default on; set to 0 to fall back to v1 baseline detector.
SPIKE_V2=1
# Min confidence (0–1) to capture a v2 spike as a moment (default 0.3)
SPIKE_MIN_CONFIDENCE=0.3

# --- Solana prediction market oracle (Phase 2) ---
HELIUS_KEY=
SOLANA_ORACLE_KEYPAIR_BASE64=
CLIPPY_PROGRAM_ID=
USDC_MINT=
ORACLE_WATCHLIST=
ORACLE_MARKET_MOODS=hype
ORACLE_WINDOW_SECONDS=300
ORACLE_FEE_BPS=200

# --- Solana prediction market frontend (Phase 3) ---
# Devnet RPC key — low risk, safe to expose client-side.
NEXT_PUBLIC_HELIUS_KEY=
NEXT_PUBLIC_CLIPPY_PROGRAM_ID=
